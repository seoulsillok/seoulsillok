---
import Layout from '../layouts/Layout.astro';
import SeoulArtMap from '../components/SeoulArtMap.astro';
import { ALL_DONGS, DISTRICTS, SOCIAL_LINKS } from '../data/seoul';

const featured = ALL_DONGS.slice(0, 9);
---

<Layout title="서울 실록" description="서울 전체 동네를 감각적으로 기록하는 아카이브">
  <section class="hero">
    <p class="eyebrow">SEOUL ARCHIVE</p>
    <h1>서울의 동네를<br />미니멀하게 기록합니다</h1>
    <p class="lead">
      Instagram 포스트를 기반으로 동네 페이지와 연결합니다.
      구를 선택하고, 연결된 동네 포스트를 바로 확인하세요.
    </p>
    <div class="hero-cta">
      <a href="/dong" class="btn dark">지도에서 탐색하기</a>
      <a href={SOCIAL_LINKS.instagram} class="btn light" target="_blank" rel="noreferrer">@seoulsillok</a>
    </div>
  </section>

  <section class="map-block">
    <header>
      <h2>서울 지도</h2>
      <p>구를 선택하면 해당 구 섹션으로 이동합니다.</p>
    </header>
    <SeoulArtMap districts={DISTRICTS} />
  </section>

  <section class="featured">
    <header>
      <h2>빠른 이동</h2>
      <p>{DISTRICTS.length}개 구 · {ALL_DONGS.length}개 동네</p>
    </header>
    <div class="cards">
      {featured.map((dong) => (
        <a class="card" href={`/dong/${dong.slug}`}>
          <small>{dong.districtKo}</small>
          <h3>{dong.nameKo}</h3>
          <span>페이지 보기</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 1.5rem 0 1.1rem;
  }

  .eyebrow {
    margin: 0;
    color: #746d61;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 700;
  }

  h1 {
    margin: 0.62rem 0 0;
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.06;
    color: #201d18;
  }

  .lead {
    margin: 1rem 0 0;
    max-width: 690px;
    color: #544c42;
    line-height: 1.72;
  }

  .hero-cta {
    margin-top: 1.2rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn {
    text-decoration: none;
    border-radius: 999px;
    padding: 0.62rem 0.95rem;
    font-size: 0.86rem;
    font-weight: 700;
    border: 1px solid #1f1d19;
  }

  .btn.dark {
    color: #fcfbf8;
    background: #1f1d19;
  }

  .btn.light {
    color: #1f1d19;
    background: #fcfbf8;
  }

  .map-block {
    margin-top: 1rem;
  }

  .map-block h2,
  .featured h2 {
    margin: 0;
    font-family: 'Fraunces', serif;
    color: #201d18;
    font-size: clamp(1.4rem, 3vw, 2rem);
  }

  .map-block p,
  .featured p {
    margin: 0.45rem 0 0.8rem;
    color: #60584d;
  }

  .featured {
    margin-top: 1.8rem;
  }

  .cards {
    margin-top: 0.8rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .card {
    padding: 0.84rem;
    border-radius: 12px;
    text-decoration: none;
    color: #201d18;
    border: 1px solid #e1dbcf;
    background: #fff;
  }

  .card:hover {
    border-color: #1f1d19;
  }

  .card small {
    color: #6a6256;
  }

  .card h3 {
    margin: 0.2rem 0 0.62rem;
    font-size: 1rem;
  }

  .card span {
    font-size: 0.78rem;
    color: #6a6256;
  }

  @media (max-width: 900px) {
    .cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
