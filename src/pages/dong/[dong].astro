---
import Layout from '../../layouts/Layout.astro';
import { findDongBySlug, getDistrictByCode, ALL_DONGS, SOCIAL_LINKS } from '../../data/seoul';

export async function getStaticPaths() {
  return ALL_DONGS.map((entry) => ({ params: { dong: entry.slug } }));
}

const slug = String(Astro.params.dong || '');
const record = findDongBySlug(slug);
const district = record ? getDistrictByCode(record.districtCode) : undefined;

const query = record ? `${record.nameKo} ${record.districtKo}` : '서울 동네';
const youtubeSearch = `https://www.youtube.com/results?search_query=${encodeURIComponent(query)}`;
const tiktokSearch = `https://www.tiktok.com/search?q=${encodeURIComponent(query)}`;
const soundcloudSearch = `https://soundcloud.com/search?q=${encodeURIComponent(query)}`;
const instagramTag = record
  ? `https://www.instagram.com/explore/tags/${encodeURIComponent(record.nameKo.replace('동', ''))}/`
  : SOCIAL_LINKS.instagram;
---

<Layout title={record ? `${record.nameKo} 기록` : '동네 기록'} description="서울 동네 기록 상세 페이지">
  {record ? (
    <article class="detail">
      <p class="eyebrow">SEOUL MEMORY SHEET</p>
      <h1>{record.nameKo}</h1>
      <p class="meta">{record.districtKo} · slug: {record.slug}</p>
      <p class="summary">
        이 페이지는 {record.nameKo} 기록을 모으기 위한 기본 아카이브입니다.
        서울 실록 채널 또는 검색 링크를 통해 관련 기록을 이어서 확인하세요.
      </p>

      <section class="channel-grid" aria-label="채널 링크">
        <a href={instagramTag} target="_blank" rel="noreferrer">
          <small>Instagram</small>
          <strong>{record.nameKo} 태그 열기</strong>
        </a>
        <a href={youtubeSearch} target="_blank" rel="noreferrer">
          <small>YouTube</small>
          <strong>{record.nameKo} 검색</strong>
        </a>
        <a href={tiktokSearch} target="_blank" rel="noreferrer">
          <small>TikTok</small>
          <strong>{record.nameKo} 검색</strong>
        </a>
        <a href={soundcloudSearch} target="_blank" rel="noreferrer">
          <small>SoundCloud</small>
          <strong>{record.nameKo} 검색</strong>
        </a>
      </section>

      <section class="actions">
        <a href={`/dong?district=${record.districtCode}`}>← {record.districtKo} 목록으로</a>
        <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noreferrer">서울실록 인스타그램</a>
      </section>

      {district ? (
        <section class="related">
          <h2>{record.districtKo}의 다른 동네</h2>
          <ul>
            {district.dongs.map((dong, index) => (
              <li>
                <a href={`/dong/${district.code}-${index + 1}`} class:list={[{ active: dong === record.nameKo }]}>{dong}</a>
              </li>
            ))}
          </ul>
        </section>
      ) : null}
    </article>
  ) : (
    <article class="detail">
      <h1>존재하지 않는 동네 페이지입니다.</h1>
      <p class="summary">요청한 경로를 찾을 수 없습니다. 동네 목록으로 이동해 주세요.</p>
      <section class="actions">
        <a href="/dong">서울 동네 목록으로 이동</a>
      </section>
    </article>
  )}
</Layout>

<style>
  .detail {
    max-width: 860px;
    margin: 0 auto;
    border: 1px solid var(--line);
    border-radius: 28px;
    padding: 1.4rem;
    background: linear-gradient(160deg, rgba(50, 37, 25, 0.78), rgba(16, 12, 8, 0.9));
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.35);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-soft);
    letter-spacing: 0.12em;
    font-size: 0.74rem;
    font-weight: 700;
  }

  h1 {
    margin: 0.8rem 0 0;
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .meta {
    color: var(--muted);
    margin: 0.45rem 0 1rem;
    font-size: 0.9rem;
  }

  .summary {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .channel-grid {
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .channel-grid a {
    border: 1px solid rgba(247, 225, 198, 0.2);
    border-radius: 15px;
    padding: 0.9rem;
    text-decoration: none;
    color: var(--text);
    background: rgba(255, 250, 244, 0.02);
  }

  .channel-grid small {
    display: block;
    color: var(--accent-soft);
  }

  .channel-grid strong {
    display: block;
    margin-top: 0.3rem;
  }

  .actions {
    margin-top: 1rem;
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .actions a {
    text-decoration: none;
    color: #180d06;
    font-weight: 700;
    border-radius: 999px;
    background: linear-gradient(135deg, #fac89f, #f58f56);
    padding: 0.46rem 0.84rem;
    font-size: 0.82rem;
  }

  .related {
    margin-top: 1.35rem;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .related ul {
    margin: 0.7rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .related a {
    text-decoration: none;
    color: var(--muted);
    border: 1px solid rgba(247, 225, 198, 0.2);
    border-radius: 999px;
    padding: 0.3rem 0.6rem;
    font-size: 0.78rem;
  }

  .related a.active {
    color: #1c1008;
    background: linear-gradient(125deg, #ffd0a8, #f58a4e);
    border-color: rgba(255, 205, 163, 0.82);
    font-weight: 700;
  }

  @media (max-width: 700px) {
    .channel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
