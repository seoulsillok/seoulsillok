---
import Layout from '../../layouts/Layout.astro';
import { findDongBySlug, getDistrictByCode, ALL_DONGS, SOCIAL_LINKS } from '../../data/seoul';
import { INSTAGRAM_POSTS_BY_DONG, INSTAGRAM_PROFILE_URL } from '../../data/instagram-posts.generated';

export async function getStaticPaths() {
  return ALL_DONGS.map((entry) => ({ params: { dong: entry.slug } }));
}

const slug = String(Astro.params.dong || '');
const record = findDongBySlug(slug);
const district = record ? getDistrictByCode(record.districtCode) : undefined;

const instagramPost = record ? INSTAGRAM_POSTS_BY_DONG[record.nameKo] : undefined;
const hasEmbeddablePost = instagramPost ? /instagram\.com\/p\//.test(instagramPost.url) : false;
---

<Layout title={record ? `${record.nameKo} 기록` : '동네 기록'} description="서울 동네 기록 상세 페이지">
  {record ? (
    <article class="detail">
      <p class="eyebrow">INSTAGRAM ARCHIVE</p>
      <h1>{record.nameKo}</h1>
      <p class="meta">{record.districtKo}</p>

      {instagramPost ? (
        <section class="post-card" aria-label="인스타그램 포스트">
          <header>
            <small>Instagram Post</small>
            <h2>{instagramPost.title}</h2>
          </header>

          {hasEmbeddablePost ? (
            <div class="embed">
              <blockquote class="instagram-media" data-instgrm-permalink={instagramPost.url} data-instgrm-version="14"></blockquote>
              <script async src="https://www.instagram.com/embed.js"></script>
            </div>
          ) : (
            <p class="note">자동 연결된 퍼머링크가 아직 없어 프로필 링크로 연결됩니다.</p>
          )}

          <pre>{instagramPost.caption}</pre>
          <a href={instagramPost.url} target="_blank" rel="noreferrer">해당 포스트 보러 가기</a>
        </section>
      ) : (
        <section class="post-card" aria-label="인스타그램 포스트 없음">
          <header>
            <small>Instagram Post</small>
            <h2>등록 대기 중</h2>
          </header>
          <p class="note">
            이 동네에 매핑된 Instagram 포스트를 아직 찾지 못했습니다.
            {record.nameKo} 키워드가 포함된 캡션 포스팅을 올리면 자동 연결됩니다.
          </p>
          <a href={INSTAGRAM_PROFILE_URL} target="_blank" rel="noreferrer">@seoulsillok 프로필 열기</a>
        </section>
      )}

      <section class="actions">
        <a href={`/dong#district-${record.districtCode}`}>← {record.districtKo} 목록으로</a>
        <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noreferrer">서울실록 인스타그램</a>
      </section>

      {district ? (
        <section class="related">
          <h2>{record.districtKo}의 다른 동네</h2>
          <ul>
            {district.dongs.map((dong, index) => (
              <li>
                <a href={`/dong/${district.code}-${index + 1}`} class:list={[{ active: dong === record.nameKo }]}>{dong}</a>
              </li>
            ))}
          </ul>
        </section>
      ) : null}
    </article>
  ) : (
    <article class="detail">
      <h1>존재하지 않는 동네 페이지입니다.</h1>
      <p class="note">요청한 경로를 찾을 수 없습니다. 동네 목록으로 이동해 주세요.</p>
      <section class="actions">
        <a href="/dong">서울 동네 목록으로 이동</a>
      </section>
    </article>
  )}
</Layout>

<style>
  .detail {
    max-width: 860px;
    margin: 0 auto;
    border: 1px solid #e4dfd4;
    border-radius: 16px;
    padding: 1.05rem;
    background: #fffdf9;
  }

  .eyebrow {
    margin: 0;
    color: #6b645a;
    letter-spacing: 0.11em;
    font-size: 0.71rem;
    font-weight: 700;
  }

  h1 {
    margin: 0.5rem 0 0;
    font-family: 'Fraunces', serif;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    color: #1e1b17;
  }

  .meta {
    color: #555045;
    margin: 0.2rem 0 0.9rem;
    font-size: 0.9rem;
  }

  .post-card {
    border: 1px solid #e7e1d6;
    border-radius: 12px;
    padding: 0.9rem;
    background: #fff;
  }

  .post-card header small {
    color: #6b645a;
  }

  .post-card h2 {
    margin: 0.25rem 0 0;
    font-size: 1.1rem;
    color: #201d18;
  }

  .embed {
    margin-top: 0.8rem;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid #ebe4d8;
    background: #fff;
  }

  pre {
    margin: 0.85rem 0;
    white-space: pre-wrap;
    font-family: 'Noto Sans KR', sans-serif;
    color: #2c281f;
    line-height: 1.66;
    font-size: 0.9rem;
  }

  .note {
    margin: 0.85rem 0;
    color: #585145;
    line-height: 1.65;
    font-size: 0.9rem;
  }

  .post-card > a,
  .actions a {
    display: inline-block;
    text-decoration: none;
    color: #1d1b16;
    border-radius: 999px;
    border: 1px solid #d6cfbf;
    background: #fff;
    padding: 0.42rem 0.72rem;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .post-card > a:hover,
  .actions a:hover {
    border-color: #1f1d19;
    background: #1f1d19;
    color: #fff;
  }

  .actions {
    margin-top: 0.9rem;
    display: flex;
    gap: 0.56rem;
    flex-wrap: wrap;
  }

  .related {
    margin-top: 1.05rem;
    border-top: 1px solid #ece7dc;
    padding-top: 0.85rem;
  }

  .related h2 {
    margin: 0;
    color: #24201a;
    font-size: 1rem;
  }

  .related ul {
    margin: 0.65rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
  }

  .related a {
    text-decoration: none;
    color: #5d564a;
    border: 1px solid #e7e1d6;
    border-radius: 999px;
    padding: 0.25rem 0.56rem;
    font-size: 0.78rem;
  }

  .related a.active {
    color: #fff;
    background: #1f1d19;
    border-color: #1f1d19;
    font-weight: 700;
  }
</style>
