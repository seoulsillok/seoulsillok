---
import Layout from '../../layouts/Layout.astro';
import SeoulArtMap from '../../components/SeoulArtMap.astro';
import { ALL_DONGS, DISTRICTS } from '../../data/seoul';
---

<Layout title="서울 동네 아카이브" description="서울 25개 구 동네 목록과 지도 탐색">
  <section class="intro">
    <p class="eyebrow">SEOUL DONG DIRECTORY</p>
    <h1>서울 동네 기록</h1>
    <p>
      지도의 구를 누르면 해당 구로 확대되고, 해당 구의 동네 목록만 표시됩니다.
      총 {DISTRICTS.length}개 구, {ALL_DONGS.length}개 동네를 연결했습니다.
    </p>
  </section>

  <section class="map-area">
    <SeoulArtMap districts={DISTRICTS} mode="interactive" />
  </section>

  <section class="filters" aria-label="구 선택 필터">
    <button type="button" data-filter-btn data-district-code="" class="active">전체 보기</button>
    {DISTRICTS.map((district) => (
      <button type="button" data-filter-btn data-district-code={district.code}>{district.nameKo}</button>
    ))}
  </section>

  <section class="status-bar" aria-live="polite">
    <p><strong data-selected-label>전체</strong> · <span data-visible-count data-total={ALL_DONGS.length}>{ALL_DONGS.length}</span>개 동네 표시 중</p>
  </section>

  <section class="district-grid">
    {DISTRICTS.map((district) => (
      <article class="district-card" id={`district-${district.code}`} data-district-card data-district-code={district.code} data-dongs={district.dongs.length}>
        <header>
          <h2>{district.nameKo}</h2>
          <small>{district.dongs.length}개 동네</small>
        </header>
        <ul>
          {district.dongs.map((dong, index) => (
            <li>
              <a href={`/dong/${district.code}-${index + 1}`}>
                <strong>{dong}</strong>
                <span>기록 보기</span>
              </a>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </section>
</Layout>

<script>
  const mapFrame = document.querySelector('[data-map-frame]');
  const mapButtons = Array.from(document.querySelectorAll('[data-district-btn]'));
  const filterButtons = Array.from(document.querySelectorAll('[data-filter-btn]'));
  const cards = Array.from(document.querySelectorAll('[data-district-card]'));
  const selectedLabel = document.querySelector('[data-selected-label]');
  const visibleCount = document.querySelector('[data-visible-count]');

  function applySelection(code) {
    const normalized = code || '';

    mapButtons.forEach((button) => {
      const isActive = button.dataset.districtCode === normalized;
      button.classList.toggle('active', isActive);
    });

    filterButtons.forEach((button) => {
      const isActive = button.dataset.districtCode === normalized;
      button.classList.toggle('active', isActive);
    });

    let count = 0;
    cards.forEach((card) => {
      const isMatch = !normalized || card.dataset.districtCode === normalized;
      card.hidden = !isMatch;
      if (isMatch) {
        count += Number(card.dataset.dongs || 0);
      }
    });

    if (selectedLabel) {
      const activeButton = mapButtons.find((button) => button.dataset.districtCode === normalized);
      selectedLabel.textContent = activeButton ? activeButton.textContent?.trim() || '선택' : '전체';
    }

    if (visibleCount) {
      visibleCount.textContent = String(count || Number(visibleCount.dataset.total || 0));
    }

    if (!mapFrame) return;

    if (!normalized) {
      mapFrame.classList.remove('is-zoomed');
      mapFrame.style.setProperty('--focus-x', '50%');
      mapFrame.style.setProperty('--focus-y', '50%');
      history.replaceState(null, '', '/dong');
      return;
    }

    const activeMapButton = mapButtons.find((button) => button.dataset.districtCode === normalized);
    const x = activeMapButton?.dataset.focusX || '50';
    const y = activeMapButton?.dataset.focusY || '50';

    mapFrame.classList.add('is-zoomed');
    mapFrame.style.setProperty('--focus-x', `${x}%`);
    mapFrame.style.setProperty('--focus-y', `${y}%`);

    history.replaceState(null, '', `/dong#district-${normalized}`);
  }

  mapButtons.forEach((button) => {
    button.addEventListener('click', () => {
      applySelection(button.dataset.districtCode || '');
    });
  });

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      applySelection(button.dataset.districtCode || '');
    });
  });

  const initialCode = location.hash.startsWith('#district-') ? location.hash.replace('#district-', '') : '';
  const isValid = cards.some((card) => card.dataset.districtCode === initialCode);
  applySelection(isValid ? initialCode : '');
</script>

<style>
  .intro {
    margin-top: 0.2rem;
  }

  .eyebrow {
    margin: 0;
    letter-spacing: 0.12em;
    color: #787064;
    font-weight: 700;
    font-size: 0.72rem;
  }

  h1 {
    margin: 0.6rem 0 0.45rem;
    font-family: 'Fraunces', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    color: #1f1d18;
  }

  .intro p {
    color: #4d463d;
    max-width: 760px;
    line-height: 1.7;
  }

  .map-area {
    margin-top: 1rem;
  }

  .filters {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .filters button {
    border: 1px solid #d8d1c3;
    background: #fcfbf8;
    color: #2b2721;
    border-radius: 999px;
    padding: 0.36rem 0.66rem;
    font-size: 0.75rem;
    cursor: pointer;
  }

  .filters button.active {
    background: #1f1d19;
    color: #fcfbf8;
    border-color: #1f1d19;
  }

  .status-bar {
    margin-top: 0.85rem;
    color: #4d463d;
    font-size: 0.92rem;
  }

  .status-bar p {
    margin: 0;
  }

  .district-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .district-card {
    border: 1px solid #e4dfd4;
    border-radius: 16px;
    padding: 0.95rem;
    background: #fffdf9;
  }

  .district-card header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.8rem;
    margin-bottom: 0.75rem;
  }

  h2 {
    margin: 0;
    color: #1f1d18;
    font-size: 1.15rem;
  }

  header small {
    color: #6a6258;
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.42rem;
  }

  li a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid #e7e1d6;
    border-radius: 10px;
    text-decoration: none;
    padding: 0.44rem 0.56rem;
    color: #24211c;
    font-size: 0.84rem;
    background: #ffffff;
  }

  li a:hover {
    border-color: #1f1d19;
  }

  li span {
    color: #70685d;
    font-size: 0.72rem;
  }

  @media (max-width: 960px) {
    .district-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    ul {
      grid-template-columns: 1fr;
    }
  }
</style>
