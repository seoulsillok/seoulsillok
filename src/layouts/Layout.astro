---
import { SOCIAL_LINKS } from '../data/seoul';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Seoul Sillok',
  description = '서울의 동네를 감각적으로 기록하는 아카이브 플랫폼'
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | 서울 실록</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <header>
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-mark">SS</span>
          <span>Seoul Sillok</span>
        </a>
        <nav>
          <a href="/">홈</a>
          <a href="/dong">서울 동네</a>
          <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noreferrer">Instagram</a>
          <a href={SOCIAL_LINKS.youtube} target="_blank" rel="noreferrer">YouTube</a>
          <a href={SOCIAL_LINKS.tiktok} target="_blank" rel="noreferrer">TikTok</a>
          <a href={SOCIAL_LINKS.soundcloud} target="_blank" rel="noreferrer">SoundCloud</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>서울 실록 Seoul Sillok</p>
      <small>&copy; {new Date().getFullYear()} All rights reserved.</small>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #15120e;
    --panel: #211a13;
    --surface: #2a2219;
    --text: #f7efe2;
    --muted: #ccbca6;
    --accent: #f57c3d;
    --accent-soft: #ffb37c;
    --line: rgba(244, 225, 198, 0.2);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at 10% -10%, #453423 0%, transparent 46%),
      radial-gradient(circle at 90% 0%, #2f4731 0%, transparent 43%),
      linear-gradient(170deg, #17130f 0%, #0f0d0b 100%);
    color: var(--text);
    font-family: 'Noto Sans KR', sans-serif;
  }

  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    opacity: 0.2;
    background-image: radial-gradient(rgba(255, 246, 232, 0.2) 0.3px, transparent 0.3px);
    background-size: 3px 3px;
  }

  header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(12px);
    background: rgba(15, 12, 9, 0.82);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0.95rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Fraunces', serif;
    font-size: 1.14rem;
    letter-spacing: 0.02em;
  }

  .logo-mark {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid rgba(245, 124, 61, 0.68);
    display: grid;
    place-items: center;
    background: rgba(245, 124, 61, 0.12);
    color: var(--accent-soft);
    font-size: 0.8rem;
    font-family: 'Noto Sans KR', sans-serif;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.92rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.89rem;
    transition: color 0.2s ease;
  }

  nav a:hover {
    color: var(--accent-soft);
  }

  main {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }

  footer {
    border-top: 1px solid var(--line);
    padding: 1.8rem 1rem 2.2rem;
    text-align: center;
    color: var(--muted);
    background: rgba(9, 8, 7, 0.62);
  }

  footer p {
    margin: 0;
    font-family: 'Fraunces', serif;
    letter-spacing: 0.04em;
  }

  footer small {
    display: block;
    margin-top: 0.35rem;
  }

  @media (max-width: 840px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    nav {
      width: 100%;
      justify-content: flex-start;
    }

    main {
      padding-top: 1.8rem;
    }
  }
</style>
