---
import { SOCIAL_LINKS } from '../data/seoul';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Seoul Sillok',
  description = '서울의 동네를 감각적으로 기록하는 아카이브 플랫폼'
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | 서울 실록</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-mark">SS</span>
          <span>Seoul Sillok</span>
        </a>
        <nav>
          <a href="/">홈</a>
          <a href="/dong">서울 동네</a>
          <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noreferrer">Instagram</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>서울 실록 Seoul Sillok</p>
      <small>&copy; {new Date().getFullYear()} All rights reserved.</small>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #f4f1ea;
    --surface: #fffdf9;
    --text: #1f1c18;
    --muted: #645c50;
    --line: #ded8cb;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at 10% 0%, #e9e4d8 0%, transparent 32%),
      radial-gradient(circle at 95% 8%, #ece8de 0%, transparent 28%),
      var(--bg);
    color: var(--text);
    font-family: 'Noto Sans KR', sans-serif;
  }

  header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(8px);
    background: rgba(244, 241, 234, 0.88);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
  }

  .logo-mark {
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 50%;
    border: 1px solid #bfb7a7;
    display: grid;
    place-items: center;
    font-size: 0.74rem;
    color: #5f5648;
    background: #faf8f2;
    font-family: 'Noto Sans KR', sans-serif;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
  }

  nav a:hover {
    color: var(--text);
  }

  main {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1rem 3.2rem;
  }

  footer {
    border-top: 1px solid var(--line);
    padding: 1.4rem 1rem 1.8rem;
    text-align: center;
    color: var(--muted);
    background: rgba(250, 248, 242, 0.8);
  }

  footer p {
    margin: 0;
    font-family: 'Fraunces', serif;
    letter-spacing: 0.03em;
  }

  footer small {
    display: block;
    margin-top: 0.28rem;
  }

  @media (max-width: 760px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    main {
      padding-top: 1.6rem;
    }
  }
</style>
