---
import type { SeoulDistrict } from '../data/seoul';

interface Props {
  districts: SeoulDistrict[];
  mode?: 'link' | 'interactive';
}

const { districts, mode = 'link' } = Astro.props;
const isInteractive = mode === 'interactive';

const districtPayload = districts.map((district) => ({
  code: district.code,
  nameKo: district.nameKo,
  x: district.map.x,
  y: district.map.y,
  dongs: district.dongs.map((dong, index) => ({
    nameKo: dong,
    slug: `${district.code}-${index + 1}`
  }))
}));
---

<section class="map-wrap" aria-label="서울 지도" data-map-root data-map-mode={mode}>
  <div class="map-frame" data-map-frame>
    <div class="map-scene" data-map-scene>
      <img src="/images/seoul_map.jpg" alt="서울 지도" loading="lazy" class="map-image" />

      <ul class="district-layer" aria-label="서울 구 선택" data-district-layer>
        {districts.map((district) => (
          <li style={`left:${district.map.x}%; top:${district.map.y}%;`}>
            {isInteractive ? (
              <button
                type="button"
                title={`${district.nameKo} 보기`}
                aria-label={`${district.nameKo} 보기`}
                aria-pressed="false"
                data-district-btn
                data-district-code={district.code}
              >
                {district.nameKo}
              </button>
            ) : (
              <a href={`/dong#district-${district.code}`} title={`${district.nameKo} 보기`}>
                {district.nameKo}
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>

    {isInteractive ? <ul class="dong-layer" data-dong-layer aria-label="선택된 구의 동"></ul> : null}

    {isInteractive ? (
      <div class="selection-badge" data-map-selection hidden>
        <strong data-map-selection-title></strong>
        <span data-map-selection-count></span>
      </div>
    ) : null}

    {isInteractive ? (
      <aside class="dong-panel" data-dong-panel hidden>
        <p class="dong-panel-label">Selected Dongs</p>
        <div class="dong-panel-grid" data-dong-panel-grid></div>
      </aside>
    ) : null}

    {isInteractive ? <button class="reset-btn" type="button" data-map-reset disabled>전체 구 보기</button> : null}
  </div>

  {isInteractive ? (
    <script type="application/json" data-map-districts set:html={JSON.stringify(districtPayload)}></script>
  ) : null}
</section>

{isInteractive ? (
  <script>
    const root = document.querySelector('[data-map-root][data-map-mode="interactive"]');

    if (root instanceof HTMLElement) {
      const scene = root.querySelector('[data-map-scene]');
      const districtButtons = Array.from(root.querySelectorAll('[data-district-btn]'));
      const dongLayer = root.querySelector('[data-dong-layer]');
      const resetButton = root.querySelector('[data-map-reset]');
      const selection = root.querySelector('[data-map-selection]');
      const selectionTitle = root.querySelector('[data-map-selection-title]');
      const selectionCount = root.querySelector('[data-map-selection-count]');
      const dongPanel = root.querySelector('[data-dong-panel]');
      const dongPanelGrid = root.querySelector('[data-dong-panel-grid]');
      const jsonEl = root.querySelector('[data-map-districts]');
      const districts = jsonEl ? JSON.parse(jsonEl.textContent || '[]') : [];
      const basePath = `${window.location.pathname}${window.location.search}`;

      const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

      const getScale = (district) => {
        const edgeDistanceX = district.x > 50 ? 100 - district.x : district.x;
        const edgeDistanceY = district.y > 50 ? 100 - district.y : district.y;
        const edgeScale = Math.max(50 / edgeDistanceX, 50 / edgeDistanceY) + 0.12;
        const densityScale = district.dongs.length > 12 ? 2.1 : district.dongs.length > 8 ? 2.25 : 2.35;

        return clamp(Math.max(edgeScale, densityScale), 2.1, 3.2);
      };

      const setSceneTransform = (district) => {
        if (!(scene instanceof HTMLElement)) return;

        if (!district) {
          scene.style.setProperty('--scene-scale', '1');
          scene.style.setProperty('--scene-x', '0%');
          scene.style.setProperty('--scene-y', '0%');
          scene.style.setProperty('--overlay-scale', '1');
          return;
        }

        const scale = getScale(district);
        const minTranslate = 100 - 100 * scale;
        const translateX = clamp(50 - district.x * scale, minTranslate, 0);
        const translateY = clamp(50 - district.y * scale, minTranslate, 0);

        scene.style.setProperty('--scene-scale', String(scale));
        scene.style.setProperty('--scene-x', `${translateX}%`);
        scene.style.setProperty('--scene-y', `${translateY}%`);
        scene.style.setProperty('--overlay-scale', String(scale));
      };

      const buildDongMarkers = (district) => {
        if (!(dongLayer instanceof HTMLElement)) return;

        dongLayer.innerHTML = '';
        if (dongPanelGrid instanceof HTMLElement) dongPanelGrid.innerHTML = '';

        const total = district.dongs.length;
        const columns = total > 12 ? 4 : total > 8 ? 3 : total > 4 ? 2 : 1;
        const rows = Math.ceil(total / columns);
        const rowCounts = Array.from({ length: rows }, (_, row) => Math.min(columns, total - row * columns));
        const gapX = columns === 4 ? 13 : columns === 3 ? 14.5 : columns === 2 ? 16 : 0;
        const gapY = total > 10 ? 8.2 : total > 6 ? 9 : 10;
        const centerY = total > 10 ? 56 : 55;

        district.dongs.forEach((dong, index) => {
          const row = Math.floor(index / columns);
          const column = index % columns;
          const itemsInRow = rowCounts[row];
          const xOffset = (column - (itemsInRow - 1) / 2) * gapX;
          const yOffsetFromCenter = (row - (rows - 1) / 2) * gapY;

          const item = document.createElement('li');
          item.style.left = `${clamp(50 + xOffset, 12, 88)}%`;
          item.style.top = `${clamp(centerY + yOffsetFromCenter, 20, 84)}%`;
          item.style.setProperty('--dong-delay', `${index * 32}ms`);
          item.style.setProperty('--dong-line', `${Math.max(16, Math.abs(yOffsetFromCenter) * 5 + 18)}px`);

          const link = document.createElement('a');
          link.href = `/dong/${dong.slug}`;
          link.textContent = dong.nameKo;
          link.title = `${dong.nameKo} 기록 보기`;
          link.setAttribute('aria-label', `${district.nameKo} ${dong.nameKo} 기록 보기`);

          item.appendChild(link);
          dongLayer.appendChild(item);

          if (dongPanelGrid instanceof HTMLElement) {
            const panelLink = document.createElement('a');
            panelLink.href = link.href;
            panelLink.textContent = dong.nameKo;
            panelLink.title = link.title;
            panelLink.setAttribute('aria-label', link.getAttribute('aria-label') || '');
            dongPanelGrid.appendChild(panelLink);
          }
        });
      };

      const applySelection = (code) => {
        const selected = districts.find((district) => district.code === code);

        districtButtons.forEach((button) => {
          const isActive = button.dataset.districtCode === code;
          button.classList.toggle('active', isActive);
          button.setAttribute('aria-pressed', String(isActive));
        });

        root.classList.toggle('has-selection', Boolean(selected));

        if (!(resetButton instanceof HTMLButtonElement)) return;

        resetButton.disabled = !selected;

        if (!selected) {
          setSceneTransform(null);
          if (dongLayer instanceof HTMLElement) dongLayer.innerHTML = '';
          if (selection instanceof HTMLElement) selection.hidden = true;
          if (dongPanel instanceof HTMLElement) dongPanel.hidden = true;
          if (dongPanelGrid instanceof HTMLElement) dongPanelGrid.innerHTML = '';
          window.dispatchEvent(new CustomEvent('district-change', { detail: { code: '' } }));
          history.replaceState(null, '', basePath);
          return;
        }

        setSceneTransform(selected);
        buildDongMarkers(selected);

        if (selection instanceof HTMLElement) selection.hidden = false;
        if (selectionTitle) selectionTitle.textContent = selected.nameKo;
        if (selectionCount) selectionCount.textContent = `${selected.dongs.length}개 동`;
        if (dongPanel instanceof HTMLElement) dongPanel.hidden = false;

        window.dispatchEvent(new CustomEvent('district-change', { detail: { code: selected.code } }));
        history.replaceState(null, '', `${basePath}#district-${selected.code}`);
      };

      districtButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const code = button.dataset.districtCode || '';
          const isAlreadyActive = button.classList.contains('active');
          applySelection(isAlreadyActive ? '' : code);
        });
      });

      resetButton.addEventListener('click', () => applySelection(''));

      const initialCode = location.hash.startsWith('#district-') ? location.hash.replace('#district-', '') : '';
      const isValid = districts.some((district) => district.code === initialCode);
      applySelection(isValid ? initialCode : '');
    }
  </script>
) : null}

<style>
  .map-wrap {
    margin: 0;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: #fbf9f5;
  }

  .map-frame {
    position: relative;
    aspect-ratio: 2598 / 2126;
    overflow: hidden;
    background: #f7f4ee;
  }

  .map-scene {
    position: absolute;
    inset: 0;
    --scene-scale: 1;
    --scene-x: 0%;
    --scene-y: 0%;
    --overlay-scale: 1;
    transform-origin: top left;
    transform: translate(var(--scene-x), var(--scene-y)) scale(var(--scene-scale));
    transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .map-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .district-layer,
  .dong-layer {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .district-layer {
    z-index: 2;
  }

  .dong-layer {
    z-index: 3;
    opacity: 0;
    transition: opacity 0.24s ease;
  }

  .map-wrap.has-selection .dong-layer {
    opacity: 1;
  }

  .district-layer li,
  .dong-layer li {
    position: absolute;
    transform: translate(-50%, -50%);
  }

  .district-layer a,
  .district-layer button {
    pointer-events: auto;
    transform: scale(calc(1 / var(--overlay-scale)));
    transform-origin: center;
  }

  .district-layer a,
  .district-layer button {
    border: 1px solid rgba(0, 0, 0, 0.24);
    border-radius: 999px;
    background: rgba(255, 253, 249, 0.96);
    color: #1f1c16;
    text-decoration: none;
    padding: 0.28rem 0.52rem;
    font-size: 0.65rem;
    line-height: 1;
    font-weight: 700;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 10px 24px rgba(31, 25, 18, 0.08);
  }

  .map-wrap[data-map-mode='interactive'] .district-layer button {
    border-color: rgba(31, 29, 25, 0.16);
    background: rgba(255, 252, 247, 0.98);
    color: #1f1d19;
    box-shadow: 0 10px 24px rgba(31, 25, 18, 0.12);
  }

  .district-layer a:hover,
  .district-layer button:hover,
  .district-layer button.active,
  .district-layer button:focus-visible {
    background: #1f1d19;
    color: #faf8f2;
    border-color: #1f1d19;
    box-shadow: 0 14px 30px rgba(31, 29, 25, 0.18);
  }

  .district-layer button:focus-visible,
  .dong-layer a:focus-visible,
  .reset-btn:focus-visible {
    outline: 2px solid #1f1d19;
    outline-offset: 2px;
  }

  .dong-layer li {
    opacity: 0;
    animation: dong-in 0.24s ease forwards;
    animation-delay: var(--dong-delay, 0ms);
  }

  .dong-layer li::before {
    content: '';
    position: absolute;
    left: 50%;
    top: calc(100% + 0.12rem);
    width: 1px;
    height: var(--dong-line, 20px);
    background: linear-gradient(180deg, rgba(31, 29, 25, 0.32), rgba(31, 29, 25, 0));
    transform: translateX(-50%);
  }

  .dong-layer a {
    display: inline-block;
    border: 1px solid #cfc7b8;
    border-radius: 999px;
    background: rgba(255, 253, 249, 0.98);
    color: #241f18;
    text-decoration: none;
    padding: 0.42rem 0.72rem;
    font-size: 0.82rem;
    line-height: 1.1;
    font-weight: 700;
    white-space: nowrap;
    pointer-events: auto;
    box-shadow: 0 16px 34px rgba(31, 25, 18, 0.14);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .dong-layer a:hover {
    border-color: #1f1d19;
    background: #fffdf9;
    transform: translateY(-1px);
  }

  .selection-badge,
  .dong-panel,
  .reset-btn {
    position: absolute;
    z-index: 4;
    border: 1px solid #d6cfbf;
    background: rgba(255, 255, 255, 0.94);
    color: #1f1d19;
    box-shadow: 0 12px 28px rgba(31, 25, 18, 0.1);
  }

  .selection-badge {
    top: 0.8rem;
    left: 0.8rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    border-radius: 999px;
    padding: 0.38rem 0.7rem;
  }

  .selection-badge strong {
    font-size: 0.78rem;
  }

  .selection-badge span {
    font-size: 0.68rem;
    color: #5d564a;
  }

  .map-wrap.has-selection .district-layer button:not(.active) {
    opacity: 0.24;
  }

  .map-wrap.has-selection .district-layer button.active {
    position: relative;
    z-index: 1;
  }

  .dong-panel {
    right: 0.8rem;
    top: 0.8rem;
    width: min(35%, 18rem);
    border-radius: 18px;
    padding: 0.8rem;
    backdrop-filter: blur(6px);
  }

  .dong-panel-label {
    margin: 0 0 0.55rem;
    color: #6a6258;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dong-panel-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem;
  }

  .dong-panel-grid a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    border: 1px solid #dbd3c4;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    color: #241f18;
    text-decoration: none;
    padding: 0.3rem 0.58rem;
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .dong-panel-grid a:hover {
    border-color: #1f1d19;
    background: #fffdf9;
  }

  .reset-btn {
    left: 0.8rem;
    bottom: 0.8rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.34rem 0.64rem;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, opacity 0.2s ease;
  }

  .reset-btn:hover:not(:disabled) {
    border-color: #1f1d19;
    background: #fffdf9;
  }

  .reset-btn:disabled {
    opacity: 0.48;
    cursor: default;
  }

  @media (max-width: 760px) {
    .district-layer a,
    .district-layer button {
      font-size: 0.55rem;
      padding: 0.2rem 0.36rem;
    }

    .dong-layer a {
      font-size: 0.64rem;
      padding: 0.34rem 0.52rem;
    }

    .selection-badge {
      top: 0.6rem;
      left: 0.6rem;
      padding: 0.32rem 0.56rem;
    }

    .dong-panel {
      left: 0.6rem;
      right: 0.6rem;
      top: auto;
      bottom: 2.9rem;
      width: auto;
      padding: 0.6rem;
    }

    .dong-panel-grid a {
      min-height: 1.85rem;
      font-size: 0.68rem;
    }

    .reset-btn {
      left: 0.6rem;
      bottom: 0.6rem;
      font-size: 0.6rem;
      padding: 0.28rem 0.5rem;
    }
  }

  @keyframes dong-in {
    from {
      opacity: 0;
      transform: translate(-50%, -42%);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
  }
</style>
