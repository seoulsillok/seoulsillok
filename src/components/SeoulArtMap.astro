---
import type { SeoulDistrict } from '../data/seoul';

interface Props {
  districts: SeoulDistrict[];
  mode?: 'link' | 'interactive';
}

const { districts, mode = 'link' } = Astro.props;
const isInteractive = mode === 'interactive';
---

<section class="map-wrap" aria-label="서울 지도" data-map-root>
  <div class="map-frame" data-map-frame>
    <img src="/images/seoul_map.jpg" alt="서울 지도" loading="lazy" class="map-image" />
    <ul class="hotspots" aria-label="서울 구 선택">
      {districts.map((district) => (
        <li style={`left:${district.map.x}%; top:${district.map.y}%;`}>
          {isInteractive ? (
            <button
              type="button"
              title={`${district.nameKo} 보기`}
              data-district-btn
              data-district-code={district.code}
              data-focus-x={district.map.x}
              data-focus-y={district.map.y}
            >
              <span>{district.nameKo}</span>
            </button>
          ) : (
            <a href={`/dong#district-${district.code}`} title={`${district.nameKo} 보기`}>
              <span>{district.nameKo}</span>
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .map-wrap {
    margin: 0;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: #fbf9f5;
  }

  .map-frame {
    position: relative;
    aspect-ratio: 2598 / 2126;
    background: #f7f4ee;
    --focus-x: 50%;
    --focus-y: 50%;
  }

  .map-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
    transform-origin: var(--focus-x) var(--focus-y);
  }

  .map-frame.is-zoomed .map-image {
    transform: scale(1.35);
  }

  .hotspots {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .hotspots li {
    position: absolute;
    transform: translate(-50%, -50%);
  }

  .hotspots a,
  .hotspots button {
    border: 1px solid rgba(0, 0, 0, 0.22);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: #1f1c16;
    text-decoration: none;
    padding: 0.28rem 0.48rem;
    font-size: 0.66rem;
    line-height: 1;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .hotspots a:hover,
  .hotspots button:hover,
  .hotspots button.active {
    background: #1f1d19;
    color: #faf8f2;
    border-color: #1f1d19;
  }

  @media (max-width: 760px) {
    .hotspots a,
    .hotspots button {
      font-size: 0.56rem;
      padding: 0.2rem 0.33rem;
    }
  }
</style>
